---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { navigation } from '../data/site';
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-navy-950/97 text-white backdrop-blur-xl">
  <div class="h-1 bg-gold-400"></div>
  <div class="container-site flex h-22 items-center justify-between gap-6">
    <Logo light />

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Navigasi utama">
      {navigation.map((item) =>
        item.children ? (
          <div class="group relative">
            <button class="flex items-center gap-1.5 text-xs font-bold tracking-[0.04em] text-slate-300 transition hover:text-gold-300">
              {item.label}
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 3.5l3 3 3-3" />
              </svg>
            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-[var(--transition-fast)]">
              <div class="w-48 overflow-hidden rounded-[6px] border border-white/10 bg-navy-950 shadow-soft">
                {item.children.map((child) => (
                  <a href={child.href} class="block border-b border-white/8 px-5 py-3.5 text-xs font-bold tracking-[0.02em] text-slate-300 transition last:border-b-0 hover:bg-white/5 hover:text-gold-300">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href!} class="text-xs font-bold tracking-[0.04em] text-slate-300 transition hover:text-gold-300">
            {item.label}
          </a>
        ),
      )}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/keahlian/" class="btn-primary hidden sm:inline-flex">Jadi Ahli</a>
      <button
        id="menu-button"
        class="flex size-11 items-center justify-center rounded-sm border border-white/20 text-white lg:hidden"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Buka menu navigasi"
      >
        <span class="menu-open"><Icon name="menu" /></span>
        <span class="menu-close hidden"><Icon name="close" /></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden border-t border-white/10 bg-navy-950 lg:hidden">
    <nav class="container-site flex flex-col py-4" aria-label="Navigasi mudah alih">
      {navigation.map((item) =>
        item.children ? (
          <div>
            <span class="flex items-center gap-1.5 border-b border-white/10 py-4 text-sm font-bold text-gold-300">
              {item.label}
            </span>
            {item.children.map((child) => (
              <a href={child.href} class="border-b border-white/8 py-3.5 pl-6 text-sm font-semibold text-slate-300 last:border-b-0">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={item.href!} class="border-b border-white/10 py-4 text-sm font-bold text-slate-200 last:border-0">
            {item.label}
          </a>
        ),
      )}
      <a href="/keahlian/" class="btn-primary mt-4 sm:hidden">Jadi Ahli PESUMA</a>
    </nav>
  </div>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>('#menu-button');
  const menu = document.querySelector<HTMLElement>('#mobile-menu');
  const openIcon = button?.querySelector('.menu-open');
  const closeIcon = button?.querySelector('.menu-close');

  const closeMenu = () => {
    menu?.classList.add('hidden');
    button?.setAttribute('aria-expanded', 'false');
    button?.setAttribute('aria-label', 'Buka menu navigasi');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
  };

  button?.addEventListener('click', () => {
    const isOpen = button.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
    } else {
      menu?.classList.remove('hidden');
      button.setAttribute('aria-expanded', 'true');
      button.setAttribute('aria-label', 'Tutup menu navigasi');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    }
  });

  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (event) => event.key === 'Escape' && closeMenu());
</script>
