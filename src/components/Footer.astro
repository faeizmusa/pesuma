---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';

const year = new Date().getFullYear();

const address = {
  line1: 'No. 35B, Jalan Alpha F U6/F,',
  line2: 'Pusat Perdagangan Subang Permai,',
  line3: '40150 Shah Alam, Selangor.',
};
---

<footer class="relative overflow-hidden border-t-4 border-gold-400 bg-navy-950 text-white grain">
  <!-- Subtle overlay -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,#050d1c_0%,#0a1a35_50%,#050d1c_100%)]"></div>
    <div class="absolute -bottom-20 left-1/4 size-[40rem] opacity-[0.04]" style="background: radial-gradient(circle, rgba(199,164,73,0.12) 0%, transparent 60%)"></div>
  </div>

  <div class="container-site relative grid gap-14 py-20 md:grid-cols-2 lg:grid-cols-[1.45fr_0.75fr_0.75fr_1fr]">
    <div>
      <Logo light />
      <p class="mt-7 max-w-md font-serif text-xl leading-8 text-slate-300">
        Menyatukan komuniti, memperkukuh amalan dan memelihara integriti profesion.
      </p>
      <div class="mt-8 flex gap-3" aria-label="Media sosial">
        {['f', 'in', 'ig'].map((label) => (
          <a href="#" aria-label={`PESUMA di ${label}`} class="flex size-9 items-center justify-center rounded-sm border border-white/15 text-[0.65rem] font-black text-slate-400 transition hover:border-gold-300 hover:text-gold-300">
            {label}
          </a>
        ))}
      </div>
    </div>

    <div>
      <h2 class="text-[0.65rem] font-extrabold tracking-[0.2em] text-gold-300 uppercase">Pautan Pantas</h2>
      <ul class="mt-5 space-y-3">
        <li><a href="/mengenai/" class="text-sm text-slate-300 hover:text-white">Tentang PESUMA</a></li>
        <li><a href="/jawatankuasa/" class="text-sm text-slate-300 hover:text-white">Jawatankuasa</a></li>
        <li><a href="/keahlian/" class="text-sm text-slate-300 hover:text-white">Keahlian</a></li>
        <li><a href="/berita/" class="text-sm text-slate-300 hover:text-white">Berita & Acara</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-[0.65rem] font-extrabold tracking-[0.2em] text-gold-300 uppercase">Maklumat</h2>
      <ul class="mt-5 space-y-3">
        <li><a href="/keahlian/" class="text-sm text-slate-300 hover:text-white">Keahlian</a></li>
        <li><a href="/jawatankuasa/" class="text-sm text-slate-300 hover:text-white">Jawatankuasa</a></li>
        <li><a href="/berita/" class="text-sm text-slate-300 hover:text-white">Berita & Acara</a></li>
        <li><a href="/kedai/" class="text-sm text-slate-300 hover:text-white">Kedai PESUMA</a></li>
        <li><a href={site.epjsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm text-slate-300 hover:text-white">Portal ePJS <Icon name="external" size={14} /></a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-[0.65rem] font-extrabold tracking-[0.2em] text-gold-300 uppercase">Hubungi Kami</h2>
      <address class="mt-5 not-italic text-sm leading-6 text-slate-300">
        Sekretariat PESUMA<br />
        {address.line1}<br />
        {address.line2}<br />
        {address.line3}
      </address>
      <a href={`mailto:${site.email}`} class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-white hover:text-gold-300">
        <Icon name="mail" size={18} /> {site.email}
      </a>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div class="container-site flex flex-col gap-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} PESUMA. Hak cipta terpelihara.</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <a href="/dasar-privasi/" class="hover:text-white">Dasar Privasi</a>
        <a href="/terma-penggunaan/" class="hover:text-white">Terma Penggunaan</a>
        <a href="/penafian/" class="hover:text-white">Penafian</a>
      </div>
    </div>
  </div>
</footer>
