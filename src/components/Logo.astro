---
interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
---

<a href="/" class="inline-flex items-center gap-3 rounded-sm" aria-label="PESUMA — Laman utama">
  <img
    src="/logo-pesuma.png"
    width="545"
    height="545"
    alt=""
    class="size-14 shrink-0 object-contain sm:size-16"
  />
  <span class="leading-none">
    <strong class:list={['block text-lg font-extrabold tracking-[0.16em] sm:text-xl', light ? 'text-white' : 'text-navy-900']}>PESUMA</strong>
    <span class:list={['mt-1.5 hidden max-w-44 text-[0.5rem] leading-3 font-semibold tracking-[0.1em] uppercase sm:block', light ? 'text-slate-400' : 'text-slate-500']}>
      Pertubuhan Gabungan Pesuruhjaya Sumpah Malaysia
    </span>
  </span>
</a>
