---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { audiences, benefits, products, quickActions, resources, site } from '../data/site';
import { getFeaturedEvent, getLatestPosts } from '../lib/content';

const posts = await getLatestPosts(3);
const featuredEvent = await getFeaturedEvent();

const dateFormat = new Intl.DateTimeFormat('ms-MY', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formatDate = (date: string) => dateFormat.format(new Date(`${date}T00:00:00+08:00`));
---

<BaseLayout>
  <section class="relative overflow-hidden bg-navy-950 text-white">
    <div class="absolute inset-0 opacity-80" aria-hidden="true">
      <div class="absolute -top-40 left-1/2 size-[34rem] rounded-full bg-navy-700/40 blur-3xl"></div>
      <div class="absolute -right-40 -bottom-40 size-[30rem] rounded-full bg-gold-500/10 blur-3xl"></div>
    </div>
    <div class="container-site relative grid min-h-[720px] items-center gap-14 py-20 lg:grid-cols-[1.08fr_0.92fr] lg:py-24">
      <div>
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-gold-300/25 bg-gold-300/8 px-4 py-2 text-xs font-bold tracking-[0.12em] text-gold-300 uppercase">
          <span class="size-1.5 rounded-full bg-gold-400"></span>
          Berkhidmat Berintegriti
        </p>
        <h1 class="max-w-4xl text-4xl leading-[1.08] font-black tracking-tight text-balance sm:text-5xl lg:text-[3.85rem]">
          Pertubuhan Profesional Untuk <span class="text-gold-300">Pesuruhjaya Sumpah Malaysia</span>
        </h1>
        <p class="mt-7 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
          PESUMA menyatukan komuniti Pesuruhjaya Sumpah seluruh Malaysia melalui kebajikan ahli, pembangunan profesional, program latihan, rujukan amalan dan jaringan berintegriti.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/keahlian/" class="btn-primary">Jadi Ahli PESUMA <Icon name="arrow" size={18} /></a>
          <a href="#program" class="btn-secondary-dark">Lihat Program Terkini</a>
        </div>
        <div class="mt-10 flex flex-wrap gap-x-5 gap-y-3 border-t border-white/10 pt-6 text-xs font-semibold text-slate-300">
          {['Kebajikan Ahli', 'Pembangunan Profesional', 'Jaringan Seluruh Malaysia'].map((item) => (
            <span class="inline-flex items-center gap-2"><Icon name="check" size={15} /> {item}</span>
          ))}
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-xl lg:max-w-none">
        <div class="absolute -inset-4 rounded-[2.25rem] border border-white/8"></div>
        <img
          src="/hero-community.svg"
          width="900"
          height="700"
          alt="Ilustrasi program dan komuniti profesional PESUMA"
          class="relative aspect-[9/7] w-full rounded-3xl object-cover shadow-2xl shadow-black/30"
          fetchpriority="high"
        />
        <div class="absolute -bottom-5 left-4 rounded-2xl border border-white/15 bg-white/95 p-4 text-navy-900 shadow-xl backdrop-blur sm:left-8 sm:p-5">
          <p class="text-xs font-extrabold tracking-wider text-gold-500 uppercase">Komuniti Profesional</p>
          <p class="mt-1 text-sm font-bold sm:text-base">Ilmu • Kebajikan • Jaringan</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 -mt-1 bg-slate-50 section-pad">
    <div class="container-site">
      <div class="text-center">
        <p class="eyebrow">Akses pantas</p>
        <h2 class="section-title mx-auto">Cari Maklumat Dengan Lebih Mudah</h2>
        <p class="section-copy mx-auto">Laluan ringkas ke maklumat yang paling kerap diperlukan oleh ahli, komuniti dan orang awam.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {quickActions.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="card group flex min-h-56 flex-col p-6 sm:p-7"
          >
            <span class="icon-shell transition group-hover:bg-gold-400 group-hover:text-navy-950"><Icon name={item.icon} /></span>
            <h3 class="mt-6 text-lg font-extrabold text-navy-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.text}</p>
            <span class="mt-auto flex items-center gap-2 pt-5 text-sm font-bold text-navy-700">
              Terokai <Icon name={item.external ? 'external' : 'arrow'} size={17} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="overflow-hidden bg-white section-pad">
    <div class="container-site grid items-center gap-14 lg:grid-cols-2 lg:gap-20">
      <div class="relative">
        <div class="aspect-[4/3] overflow-hidden rounded-3xl bg-navy-900 p-7 sm:p-10">
          <div class="flex h-full flex-col justify-between rounded-2xl border border-white/12 bg-gradient-to-br from-white/10 to-transparent p-7 sm:p-9">
            <span class="flex size-16 items-center justify-center rounded-2xl bg-gold-400 text-2xl font-black text-navy-950">P</span>
            <div>
              <p class="text-sm font-bold tracking-[0.16em] text-gold-300 uppercase">PESUMA</p>
              <p class="mt-4 max-w-sm text-2xl leading-snug font-extrabold text-white sm:text-3xl">Memperkasa komuniti melalui ilmu, sokongan dan hubungan profesional.</p>
            </div>
          </div>
        </div>
        <div class="absolute -right-3 -bottom-6 w-44 rounded-2xl bg-gold-400 p-5 text-navy-950 shadow-xl sm:right-8 sm:w-52">
          <p class="text-3xl font-black">Malaysia</p>
          <p class="mt-1 text-xs leading-5 font-bold">Jaringan ahli merentasi negeri dan wilayah</p>
        </div>
      </div>
      <div>
        <p class="eyebrow">Mengenai PESUMA</p>
        <h2 class="section-title">Payung Profesional Untuk Komuniti Pesuruhjaya Sumpah</h2>
        <p class="section-copy">
          PESUMA berperanan sebagai wadah gabungan, sokongan dan pembangunan profesional kepada Pesuruhjaya Sumpah di Malaysia. Melalui program ilmu, aktiviti kebajikan, jaringan ahli dan sumber rujukan, PESUMA membantu memperkukuh amalan yang berintegriti, tersusun dan selari dengan keperluan semasa.
        </p>
        <a href="/mengenai/" class="btn-secondary mt-8">Ketahui Mengenai PESUMA <Icon name="arrow" size={18} /></a>
      </div>
    </div>
  </section>

  <section class="bg-navy-900 text-white section-pad">
    <div class="container-site">
      <div class="max-w-3xl">
        <p class="eyebrow">Untuk semua</p>
        <h2 class="text-3xl leading-tight font-extrabold tracking-tight sm:text-4xl">Apa Yang Anda Boleh Dapatkan Di Laman Ini?</h2>
      </div>
      <div class="mt-12 grid gap-px overflow-hidden rounded-3xl bg-white/12 md:grid-cols-3">
        {audiences.map((item) => (
          <article class="bg-navy-900 p-7 sm:p-9">
            <span class="text-sm font-black text-gold-300">{item.number}</span>
            <h3 class="mt-8 text-xl font-extrabold">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p>
          </article>
        ))}
      </div>
      <p class="mt-8 max-w-4xl border-l-2 border-gold-400 pl-5 text-sm leading-7 text-slate-300">
        Maklumat rasmi berkaitan pelantikan, direktori, peraturan dan status Pesuruhjaya Sumpah hendaklah dirujuk kepada portal rasmi pihak berkuasa berkaitan.
      </p>
    </div>
  </section>

  <section class="bg-cream-50 section-pad">
    <div class="container-site">
      <div class="flex flex-col gap-7 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="eyebrow">Keahlian</p>
          <h2 class="section-title">Kenapa Sertai PESUMA?</h2>
          <p class="section-copy">Keahlian yang menghubungkan anda dengan ilmu, sokongan dan komuniti profesional yang berkongsi matlamat.</p>
        </div>
        <a href="/keahlian/" class="btn-primary shrink-0">Daftar Sebagai Ahli <Icon name="arrow" size={18} /></a>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {benefits.map((item, index) => (
          <article class:list={['card p-6', index === 0 && 'sm:col-span-2 lg:col-span-1']}>
            <span class="icon-shell"><Icon name={item.icon} /></span>
            <h3 class="mt-6 text-lg leading-snug font-extrabold text-navy-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="container-site">
      <div class="flex flex-col gap-7 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Kemas kini komuniti</p>
          <h2 class="section-title">Berita, Program & Aktiviti Terkini</h2>
        </div>
        <a href="/berita/" class="hidden items-center gap-2 text-sm font-extrabold text-navy-700 hover:text-gold-500 sm:inline-flex">
          Lihat Semua Berita & Acara <Icon name="arrow" size={18} />
        </a>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {posts.map((post, index) => (
          <article class="card group overflow-hidden">
            <div class:list={[
              'relative flex aspect-[16/9] items-end overflow-hidden p-6',
              index === 0 ? 'bg-navy-900' : index === 1 ? 'bg-slate-800' : 'bg-navy-700',
            ]}>
              <div class="absolute -top-12 -right-8 size-40 rounded-full border-[28px] border-gold-400/10"></div>
              <div class="absolute right-12 -bottom-14 size-32 rotate-45 rounded-3xl bg-white/5"></div>
              <span class="relative rounded-full bg-gold-400 px-3 py-1.5 text-[0.68rem] font-extrabold tracking-wider text-navy-950 uppercase">{post.category}</span>
            </div>
            <div class="p-6 sm:p-7">
              <time datetime={post.date} class="text-xs font-bold text-slate-500">{formatDate(post.date)}</time>
              <h3 class="mt-3 text-xl leading-snug font-extrabold text-navy-900 transition group-hover:text-navy-700">
                <a href={`/berita/${post.slug}/`}>{post.title}</a>
              </h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{post.excerpt}</p>
              <a href={`/berita/${post.slug}/`} class="mt-6 inline-flex items-center gap-2 text-sm font-extrabold text-navy-700">Baca Lanjut <Icon name="arrow" size={17} /></a>
            </div>
          </article>
        ))}
      </div>
      <a href="/berita/" class="btn-secondary mt-8 w-full sm:hidden">Lihat Semua Berita & Acara</a>
    </div>
  </section>

  <section class="bg-slate-100 section-pad">
    <div class="container-site">
      <div class="text-center">
        <p class="eyebrow">Pusat rujukan</p>
        <h2 class="section-title mx-auto">Sumber Penting Untuk Pesuruhjaya Sumpah</h2>
        <p class="section-copy mx-auto">Akses lebih tersusun kepada maklumat rujukan dan pautan rasmi yang berkaitan dengan amalan.</p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {resources.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-gold-500/40 hover:shadow-card"
          >
            <span class="icon-shell size-11"><Icon name={item.icon} size={21} /></span>
            <span class="flex-1 text-sm font-extrabold text-navy-900">{item.title}</span>
            <Icon name={item.external ? 'external' : 'arrow'} size={17} />
          </a>
        ))}
      </div>
      <p class="mx-auto mt-8 max-w-4xl text-center text-xs leading-6 text-slate-500">
        PESUMA menyediakan pautan dan ringkasan rujukan untuk kemudahan pengguna. Untuk maklumat rasmi dan terkini, sila rujuk portal rasmi pihak berkuasa berkaitan.
      </p>
    </div>
  </section>

  <section id="program" class="overflow-hidden bg-white section-pad">
    <div class="container-site grid items-center gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-20">
      <div>
        <p class="eyebrow">Program pilihan</p>
        <h2 class="section-title">Program Pembangunan Profesional</h2>
        <p class="section-copy">
          PESUMA menganjurkan dan menyokong program ilmu, seminar, bengkel serta aktiviti komuniti bagi memperkukuh kefahaman, amalan dan integriti Pesuruhjaya Sumpah.
        </p>
        <a href="/berita/" class="btn-secondary mt-8">Terokai Semua Program <Icon name="arrow" size={18} /></a>
      </div>

      {featuredEvent && (
        <article class="relative overflow-hidden rounded-3xl bg-navy-900 p-7 text-white shadow-2xl shadow-navy-900/20 sm:p-10">
          <div class="absolute top-0 right-0 size-64 rounded-full bg-gold-400/10 blur-2xl"></div>
          <div class="relative">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <span class="rounded-full bg-gold-400 px-3 py-1.5 text-xs font-extrabold text-navy-950">{featuredEvent.status}</span>
              <span class="text-xs font-bold tracking-wider text-slate-300 uppercase">Acara Pilihan</span>
            </div>
            <h3 class="mt-8 max-w-xl text-2xl leading-tight font-extrabold sm:text-3xl">{featuredEvent.title}</h3>
            <p class="mt-4 max-w-xl text-sm leading-7 text-slate-300">{featuredEvent.excerpt}</p>
            <div class="mt-8 grid gap-4 border-y border-white/12 py-6 sm:grid-cols-2">
              <div class="flex items-center gap-3">
                <span class="text-gold-300"><Icon name="calendar" size={21} /></span>
                <div><p class="text-[0.68rem] font-bold text-slate-400 uppercase">Tarikh</p><p class="mt-1 text-sm font-bold">{formatDate(featuredEvent.date)}</p></div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-gold-300"><Icon name="location" size={21} /></span>
                <div><p class="text-[0.68rem] font-bold text-slate-400 uppercase">Lokasi</p><p class="mt-1 text-sm font-bold">{featuredEvent.location}</p></div>
              </div>
            </div>
            <a href={featuredEvent.registrationUrl || `/acara/${featuredEvent.slug}/`} class="btn-primary mt-7">Maklumat Lanjut <Icon name="arrow" size={18} /></a>
          </div>
        </article>
      )}
    </div>
  </section>

  <section class="bg-gold-400">
    <div class="container-site grid items-center gap-8 py-14 lg:grid-cols-[1fr_auto] lg:py-16">
      <div class="flex gap-5">
        <span class="hidden size-14 shrink-0 items-center justify-center rounded-2xl bg-navy-950 text-gold-300 sm:flex"><Icon name="search" size={27} /></span>
        <div>
          <h2 class="text-2xl leading-tight font-black text-navy-950 sm:text-3xl">Mencari Pesuruhjaya Sumpah Berdaftar?</h2>
          <p class="mt-3 max-w-3xl text-sm leading-7 font-medium text-navy-950/75">
            Untuk semakan direktori lantikan semasa, status lantikan atau maklumat rasmi berkaitan Pesuruhjaya Sumpah, sila rujuk portal rasmi ePJS yang disediakan oleh pihak berkuasa berkaitan.
          </p>
        </div>
      </div>
      <a href={site.epjsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-navy-950 px-6 py-3 text-sm font-extrabold text-white transition hover:-translate-y-0.5 hover:bg-navy-800">
        Semak Direktori Rasmi ePJS <Icon name="external" size={17} />
      </a>
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="container-site">
      <div class="flex flex-col gap-7 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Kedai PESUMA</p>
          <h2 class="section-title">Cenderahati & Keperluan Rasmi PESUMA</h2>
        </div>
        <a href="/kedai/" class="btn-secondary shrink-0">Lihat Kedai PESUMA <Icon name="arrow" size={18} /></a>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((product, index) => (
          <article class="group">
            <div class:list={[
              'relative aspect-[4/3] overflow-hidden rounded-2xl',
              product.tone === 'navy' ? 'bg-navy-900' : product.tone === 'gold' ? 'bg-gold-400' : 'bg-slate-200',
            ]}>
              <div class="absolute inset-8 rounded-[2rem] border border-white/20"></div>
              <div class:list={[
                'absolute top-1/2 left-1/2 flex size-28 -translate-1/2 items-center justify-center rounded-full shadow-2xl transition duration-500 group-hover:scale-105',
                index === 1 ? 'bg-navy-900 text-gold-300' : 'bg-white text-navy-900',
              ]}>
                <Icon name={index === 0 ? 'star' : index === 1 ? 'book' : 'bag'} size={42} strokeWidth={1.4} />
              </div>
            </div>
            <p class="mt-5 text-xs font-bold tracking-wider text-gold-500 uppercase">{product.category}</p>
            <h3 class="mt-2 text-lg font-extrabold text-navy-900">{product.name}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-100 px-5 py-12 sm:px-7 sm:py-16">
    <div class="mx-auto max-w-7xl overflow-hidden rounded-3xl bg-navy-900 px-6 py-14 text-center text-white shadow-2xl shadow-navy-900/15 sm:px-12 sm:py-20">
      <p class="text-xs font-extrabold tracking-[0.18em] text-gold-300 uppercase">Bersama PESUMA</p>
      <h2 class="mx-auto mt-5 max-w-3xl text-3xl leading-tight font-black tracking-tight sm:text-4xl lg:text-5xl">Bersama Memperkukuh Integriti Profesion</h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-slate-300">
        Sertai komuniti PESUMA dan bersama membina jaringan Pesuruhjaya Sumpah yang profesional, berilmu dan berintegriti.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/keahlian/" class="btn-primary">Daftar Sebagai Ahli <Icon name="arrow" size={18} /></a>
        <a href="/hubungi/" class="btn-secondary-dark">Hubungi PESUMA</a>
      </div>
    </div>
  </section>
</BaseLayout>
