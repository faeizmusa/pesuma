---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import VisualPlaceholder from '../components/VisualPlaceholder.astro';
import { audiences, benefits, products, quickActions, resources, site } from '../data/site';
import { getFeaturedEvent, getLatestPosts } from '../lib/content';

const posts = await getLatestPosts(3);
const featuredEvent = await getFeaturedEvent();

const dateFormat = new Intl.DateTimeFormat('ms-MY', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formatDate = (date: string) => dateFormat.format(new Date(`${date}T00:00:00+08:00`));
---

<BaseLayout>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative overflow-hidden bg-navy-950 text-white">
    <div class="absolute inset-0" aria-hidden="true">
      <!-- Deep gradient base with smooth stops -->
      <div class="absolute inset-0 bg-[linear-gradient(145deg,#050d1c_0%,#0a1a35_40%,#0e2240_65%,#050d1c_100%)]"></div>

      <!-- Mesh gradient: dual radial glows for depth -->
      <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse 70% 50% at 25% 25%, rgba(199,164,73,0.10) 0%, transparent 55%), radial-gradient(ellipse 50% 40% at 75% 70%, rgba(199,164,73,0.06) 0%, transparent 50%)"></div>

      <!-- Diagonal tech lines -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(65deg, transparent, transparent 120px, rgba(199,164,73,0.06) 120px, rgba(199,164,73,0.06) 121px)"></div>

      <!-- Diagonal gold accent sweep -->
      <div class="absolute -top-1/4 -right-1/4 h-[150%] w-[28%] rotate-[20deg] opacity-[0.03] bg-gold-400"></div>
      <div class="absolute -top-1/4 -right-1/4 h-[150%] w-px rotate-[20deg] opacity-[0.07] bg-gold-400"></div>

      <!-- Floating glow orbs -->
      <div class="absolute top-[15%] left-[6%] size-2 rounded-full bg-gold-400/20 blur-[3px]"></div>
      <div class="absolute top-[55%] right-[10%] size-2.5 rounded-full bg-gold-400/12 blur-[4px]"></div>
      <div class="absolute bottom-[20%] left-[18%] size-1.5 rounded-full bg-gold-400/15 blur-[2px]"></div>
      <div class="absolute top-[75%] right-[25%] size-1 rounded-full bg-gold-400/20 blur-sm"></div>
      <div class="absolute top-[35%] left-[45%] size-1 rounded-full bg-gold-400/10 blur-sm"></div>
    </div>

    <div class="container-site relative grid min-h-[720px] items-center gap-14 py-20 lg:grid-cols-[1.15fr_0.85fr] lg:py-28">
      <div class="max-w-4xl">
        <p class="mb-8 text-[0.68rem] font-bold tracking-[0.28em] text-gold-300 uppercase">Berkhidmat Berintegriti</p>
        <h1 class="font-serif text-[2.5rem] leading-[1.05] font-normal tracking-[-0.03em] text-balance sm:text-[3.25rem] lg:text-[4rem]">
          Persatuan profesional bagi <em class="font-normal text-gold-300 not-italic">Pesuruhjaya Sumpah</em> Malaysia
        </h1>
        <p class="mt-8 max-w-2xl border-l border-gold-400/60 pl-6 text-base leading-8 text-slate-300 sm:text-lg">
          PESUMA menyatukan komuniti melalui kebajikan ahli, pembangunan profesional, program ilmu, sumber rujukan dan jaringan yang berintegriti.
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href="/keahlian/" class="btn-primary">Jadi Ahli PESUMA <Icon name="arrow" /></a>
          <a href="#program" class="btn-secondary-dark">Program Terkini</a>
        </div>
      </div>

      <div class="relative hidden min-h-[480px] lg:block">
        <div class="absolute inset-0 border border-white/10 bg-white/[0.025] rounded-sm"></div>
        <div class="relative flex h-full flex-col items-center justify-center p-12 text-center">
          <img src="/logo-pesuma.png" width="546" height="546" alt="Logo rasmi PESUMA" class="w-44 opacity-90" loading="eager" />

          <div class="mt-8 grid grid-cols-3 gap-x-6 gap-y-3">
            <div>
              <strong class="block font-serif text-3xl font-normal text-gold-300">18</strong>
              <span class="text-[0.55rem] tracking-[0.18em] text-slate-400 uppercase">Ahli Jawatankuasa</span>
            </div>
            <div>
              <strong class="block font-serif text-3xl font-normal text-gold-300">10</strong>
              <span class="text-[0.55rem] tracking-[0.18em] text-slate-400 uppercase">Biro &amp; AJK</span>
            </div>
            <div>
              <strong class="block font-serif text-3xl font-normal text-gold-300">6</strong>
              <span class="text-[0.55rem] tracking-[0.18em] text-slate-400 uppercase">Negeri Diliputi</span>
            </div>
          </div>

          <div class="mt-8 border-t border-white/10 pt-6">
            <p class="font-serif text-lg text-slate-300">Berkhidmat Berintegriti</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Value bar -->
    <div class="border-t border-white/10">
      <div class="container-site grid divide-y divide-white/10 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
        {['Kebajikan Ahli', 'Pembangunan Profesional', 'Jaringan Seluruh Malaysia'].map((item, index) => (
          <div class="flex items-center gap-4 py-5 sm:px-6 first:sm:pl-0">
            <span class="font-serif text-xl text-gold-300">0{index + 1}</span>
            <span class="text-[0.68rem] font-bold tracking-[0.14em] text-slate-300 uppercase">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ QUICK LINKS ═══════════ -->
  <section class="bg-cream-50 py-10 sm:py-14">
    <div class="container-site">
      <div class="grid border-y border-navy-900/15 sm:grid-cols-2 lg:grid-cols-3">
        {quickActions.map((item, index) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="group flex min-h-32 items-start gap-5 border-b border-navy-900/15 py-7 sm:px-7 sm:nth-[2n]:border-l lg:border-l lg:nth-[3n+1]:border-l-0 lg:nth-last-[-n+3]:border-b-0"
          >
            <span class="pt-1 font-serif text-xl text-gold-500">0{index + 1}</span>
            <span class="flex-1">
              <strong class="block font-serif text-xl font-normal text-navy-900 transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500">{item.title}</strong>
              <span class="mt-2 block text-sm leading-6 text-slate-600">{item.text}</span>
            </span>
            <span class="mt-1 shrink-0 text-navy-900 transition-transform duration-[var(--transition-fast)] group-hover:translate-x-1">
              <Icon name={item.external ? 'external' : 'arrow'} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ TENTANG PESUMA ═══════════ -->
  <section class="bg-white section-pad">
    <div class="container-site grid gap-14 lg:grid-cols-[0.72fr_1.28fr] lg:gap-24">
      <div>
        <p class="eyebrow">Mengenai PESUMA</p>
        <VisualPlaceholder variant="cream" aspect="square" />
      </div>
      <div class="lg:pt-14">
        <h2 class="section-title">Sebuah wadah yang menyatukan profesion, ilmu dan kebajikan.</h2>
        <div class="mt-9 grid gap-8 border-t border-navy-900/15 pt-8 md:grid-cols-[1fr_0.8fr]">
          <p class="text-lg leading-9 text-slate-700">
            PESUMA berperanan sebagai platform gabungan, sokongan dan pembangunan profesional kepada Pesuruhjaya Sumpah di Malaysia—membantu memperkukuh amalan yang tersusun, relevan dan berintegriti.
          </p>
          <div>
            <p class="text-sm leading-7 text-slate-600">Melalui program ilmu, aktiviti kebajikan, jaringan ahli dan sumber rujukan, komuniti dapat berkembang bersama keperluan semasa.</p>
            <a href="/mengenai/" class="link-arrow mt-7">Kenali PESUMA <Icon name="arrow" /></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ AUDIENS ═══════════ -->
  <section class="bg-navy-900 text-white section-pad">
    <div class="container-site">
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
        <div>
          <p class="eyebrow">Untuk komuniti</p>
          <h2 class="max-w-xl font-serif text-[1.875rem] leading-[1.12] font-normal sm:text-[2.25rem]">Maklumat yang relevan untuk setiap lapisan pengguna.</h2>
          <p class="mt-7 max-w-md text-sm leading-7 text-slate-300">Daripada ahli PESUMA hingga orang awam dan organisasi yang ingin memahami peranan Pesuruhjaya Sumpah.</p>
        </div>
        <div class="border-t border-white/15">
          {audiences.map((item) => (
            <article class="grid gap-4 border-b border-white/15 py-8 sm:grid-cols-[4rem_0.8fr_1fr] sm:items-start">
              <span class="font-serif text-2xl text-gold-300">{item.number}</span>
              <h3 class="font-serif text-2xl font-normal">{item.title}</h3>
              <p class="text-sm leading-7 text-slate-300">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
      <p class="mt-10 max-w-5xl border-l border-gold-400 pl-6 text-xs leading-6 text-slate-400">
        Maklumat rasmi berkaitan pelantikan, direktori, peraturan dan status Pesuruhjaya Sumpah hendaklah dirujuk kepada portal rasmi pihak berkuasa berkaitan.
      </p>
    </div>
  </section>

  <!-- ═══════════ KEABILAN ═══════════ -->
  <section class="bg-cream-50 section-pad">
    <div class="container-site">
      <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-24">
        <div>
          <p class="eyebrow">Keahlian PESUMA</p>
          <h2 class="section-title">Lebih daripada sebuah keahlian.</h2>
          <p class="section-copy">Ia adalah akses kepada komuniti, ilmu dan sokongan yang memahami realiti profesion.</p>
          <a href="/keahlian/" class="btn-primary mt-9">Daftar Sebagai Ahli <Icon name="arrow" /></a>
        </div>
        <div class="grid border-t border-navy-900/15 sm:grid-cols-2">
          {benefits.map((item, index) => (
            <article class:list={['border-b border-navy-900/15 py-8 sm:px-8', index % 2 === 1 && 'sm:border-l', index === benefits.length - 1 && 'sm:col-span-2']}>
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-serif text-2xl font-normal text-navy-900">{item.title}</h3>
                <span class="text-[0.65rem] font-bold tracking-widest text-gold-500">0{index + 1}</span>
              </div>
              <p class="mt-4 max-w-xl text-sm leading-7 text-slate-600">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ BERITA & AKTIVITI ═══════════ -->
  <section class="bg-white section-pad">
    <div class="container-site">
      <div class="flex flex-col gap-8 border-b border-navy-900/15 pb-9 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Berita & perkembangan</p>
          <h2 class="section-title">Dari komuniti PESUMA</h2>
        </div>
        <a href="/berita/" class="link-arrow">Semua Berita & Acara <Icon name="arrow" /></a>
      </div>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_0.8fr]">
        {posts[0] && (
          <article class="group border-b border-navy-900/15 pb-10 lg:border-r lg:border-b-0 lg:pr-12">
            <VisualPlaceholder variant="navy" aspect="wide" label={posts[0].category} />
            <time datetime={posts[0].date} class="mt-7 block text-[0.65rem] font-bold tracking-widest text-slate-500 uppercase">{formatDate(posts[0].date)}</time>
            <h3 class="mt-4 max-w-3xl font-serif text-3xl leading-tight font-normal text-navy-900 sm:text-4xl">
              <a href={`/berita/${posts[0].slug}/`} class="transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500">{posts[0].title}</a>
            </h3>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">{posts[0].excerpt}</p>
          </article>
        )}
        <div class="divide-y divide-navy-900/15">
          {posts.slice(1).map((post) => (
            <article class="group py-8 first:pt-0">
              <div class="flex items-center justify-between gap-4">
                <span class="text-[0.62rem] font-bold tracking-[0.16em] text-gold-500 uppercase">{post.category}</span>
                <time datetime={post.date} class="text-[0.62rem] text-slate-500">{formatDate(post.date)}</time>
              </div>
              <h3 class="mt-5 font-serif text-2xl leading-snug font-normal text-navy-900 sm:text-3xl">
                <a href={`/berita/${post.slug}/`} class="transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500">{post.title}</a>
              </h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{post.excerpt}</p>
              <a href={`/berita/${post.slug}/`} class="link-arrow mt-5">Baca Lanjut <Icon name="arrow" /></a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ PROGRAM PILIHAN ═══════════ -->
  <section id="program" class="bg-navy-950 text-white section-pad">
    <div class="container-site grid gap-14 lg:grid-cols-[0.76fr_1.24fr] lg:gap-24">
      <div>
        <p class="eyebrow">Program pilihan</p>
        <h2 class="font-serif text-[1.875rem] leading-[1.12] font-normal sm:text-[2.25rem]">Pembangunan profesional yang relevan.</h2>
        <p class="mt-7 max-w-lg text-base leading-8 text-slate-300">Program ilmu, seminar dan bengkel yang menyokong kefahaman, amalan serta integriti Pesuruhjaya Sumpah.</p>
      </div>
      {featuredEvent && (
        <article class="border-y border-white/15 py-9">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <span class="text-[0.65rem] font-bold tracking-[0.18em] text-gold-300 uppercase">{featuredEvent.status}</span>
            <span class="text-[0.65rem] tracking-[0.18em] text-slate-500 uppercase">Acara pilihan</span>
          </div>
          <h3 class="mt-8 max-w-3xl font-serif text-4xl leading-tight font-normal sm:text-5xl">{featuredEvent.title}</h3>
          <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-300">{featuredEvent.excerpt}</p>
          <div class="mt-9 grid gap-6 border-t border-white/15 pt-7 sm:grid-cols-2">
            <div><p class="text-[0.6rem] font-bold tracking-widest text-slate-500 uppercase">Tarikh</p><p class="mt-2 font-serif text-xl text-gold-300">{formatDate(featuredEvent.date)}</p></div>
            <div><p class="text-[0.6rem] font-bold tracking-widest text-slate-500 uppercase">Lokasi</p><p class="mt-2 font-serif text-xl text-gold-300">{featuredEvent.location}</p></div>
          </div>
          <a href={featuredEvent.registrationUrl || `/acara/${featuredEvent.slug}/`} class="btn-primary mt-9">Maklumat Lanjut <Icon name="arrow" /></a>
        </article>
      )}
    </div>
  </section>

  <!-- ═══════════ SUMBER ═══════════ -->
  <section class="bg-cream-50 section-pad">
    <div class="container-site grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:gap-24">
      <div>
        <p class="eyebrow">Pusat rujukan</p>
        <h2 class="section-title">Sumber penting, dihimpunkan dengan lebih tersusun.</h2>
        <p class="section-copy">Pautan pantas kepada panduan, borang dan sumber rasmi berkaitan amalan.</p>
      </div>
      <div class="border-t border-navy-900/15">
        {resources.map((item, index) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="group grid grid-cols-[2.5rem_1fr_auto] items-center gap-4 border-b border-navy-900/15 py-6"
          >
            <span class="font-serif text-lg text-gold-500">0{index + 1}</span>
            <span class="font-serif text-xl text-navy-900 transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500 sm:text-2xl">{item.title}</span>
            <span class="transition-transform duration-[var(--transition-fast)] group-hover:translate-x-1"><Icon name={item.external ? 'external' : 'arrow'} /></span>
          </a>
        ))}
        <p class="mt-7 text-xs leading-6 text-slate-500">PESUMA menyediakan pautan dan ringkasan rujukan untuk kemudahan pengguna. Untuk maklumat rasmi dan terkini, sila rujuk portal rasmi pihak berkuasa berkaitan.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════ EPJS CTA ═══════════ -->
  <section class="border-y border-gold-400/35 bg-white">
    <div class="container-site grid items-center gap-8 py-14 lg:grid-cols-[1fr_auto]">
      <div>
        <p class="text-[0.65rem] font-bold tracking-[0.2em] text-gold-500 uppercase">Direktori rasmi</p>
        <h2 class="mt-4 font-serif text-3xl font-normal text-navy-900 sm:text-4xl">Mencari Pesuruhjaya Sumpah berdaftar?</h2>
        <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">Semakan direktori, status lantikan dan maklumat rasmi hendaklah dibuat melalui portal ePJS pihak berkuasa berkaitan.</p>
      </div>
      <a href={site.epjsUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary group">
        Semak Portal ePJS <Icon name="external" />
      </a>
    </div>
  </section>

  <!-- ═══════════ KEDAI ═══════════ -->
  <section class="bg-white section-pad">
    <div class="container-site">
      <div class="grid gap-10 lg:grid-cols-[0.55fr_1.45fr]">
        <div>
          <p class="eyebrow">Kedai PESUMA</p>
          <h2 class="section-title">Identiti komuniti.</h2>
          <a href="/kedai/" class="link-arrow mt-8">Lihat Kedai <Icon name="arrow" /></a>
        </div>
        <div class="grid border-t border-navy-900/15 sm:grid-cols-3">
          {products.map((product) => (
            <article class="group border-b border-navy-900/15 py-7 sm:border-l sm:px-7">
              <span class="text-[0.62rem] font-bold tracking-widest text-gold-500 uppercase">{product.category}</span>
              <VisualPlaceholder variant="cream" aspect="tall" class="my-5" />
              <h3 class="font-serif text-xl font-normal text-navy-900 transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500">{product.name}</h3>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA AKHIR ═══════════ -->
  <section class="relative overflow-hidden bg-navy-900 px-5 py-20 text-white sm:px-8 lg:py-28">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 bg-[linear-gradient(160deg,#0e2240_0%,#050d1c_100%)]"></div>
      <div class="absolute -bottom-40 -left-40 size-[50rem] opacity-30" style="background: radial-gradient(circle, rgba(199,164,73,0.10) 0%, transparent 60%)"></div>
      <div class="absolute top-[20%] right-[8%] size-1.5 rounded-full bg-gold-400/20 blur-sm"></div>
      <div class="absolute bottom-[30%] right-[20%] size-2 rounded-full bg-gold-400/15 blur-[2px]"></div>
    </div>
    <div class="relative mx-auto max-w-5xl text-center">
      <p class="text-[0.65rem] font-bold tracking-[0.24em] text-gold-300 uppercase">Bersama PESUMA</p>
      <h2 class="mt-7 font-serif text-[1.875rem] leading-[1.12] font-normal sm:text-[2.25rem] lg:text-[2.75rem]">Bersama memperkukuh integriti profesion.</h2>
      <p class="mx-auto mt-7 max-w-2xl text-base leading-8 text-slate-300">Sertai komuniti profesional yang berkembang melalui ilmu, kebajikan dan jaringan berintegriti.</p>
      <div class="mt-10 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/keahlian/" class="btn-primary">Daftar Sebagai Ahli <Icon name="arrow" /></a>
        <a href="/hubungi/" class="btn-secondary-dark">Hubungi PESUMA</a>
      </div>
    </div>
  </section>
</BaseLayout>
