---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import VisualPlaceholder from '../../components/VisualPlaceholder.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getAllPosts, getAllEvents } from '../../lib/content';

const posts = await getAllPosts();
const events = await getAllEvents();

const upcomingEvents = events.filter((e) => e.status !== 'Selesai');
const pastEvents = events.filter((e) => e.status === 'Selesai');

const featuredPost = posts[0] ?? null;
const remainingPosts = posts.slice(1);

const dateFormat = new Intl.DateTimeFormat('ms-MY', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const formatDate = (date: string) => dateFormat.format(new Date(`${date}T00:00:00+08:00`));
---

<BaseLayout
  title="Berita & Acara | PESUMA"
  description="Ikuti perkembangan terkini, program, seminar dan aktiviti PESUMA."
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative overflow-hidden bg-navy-950 text-white">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 bg-[linear-gradient(145deg,#050d1c_0%,#0a1a35_40%,#0e2240_65%,#050d1c_100%)]"></div>
      <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse 70% 50% at 25% 25%, rgba(199,164,73,0.10) 0%, transparent 55%), radial-gradient(ellipse 50% 40% at 75% 70%, rgba(199,164,73,0.06) 0%, transparent 50%)"></div>
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(65deg, transparent, transparent 120px, rgba(199,164,73,0.06) 120px, rgba(199,164,73,0.06) 121px)"></div>
      <div class="absolute -top-1/4 -right-1/4 h-[150%] w-[28%] rotate-[20deg] opacity-[0.03] bg-gold-400"></div>
      <div class="absolute -top-1/4 -right-1/4 h-[150%] w-px rotate-[20deg] opacity-[0.07] bg-gold-400"></div>
      <div class="absolute top-[15%] left-[6%] size-2 rounded-full bg-gold-400/20 blur-[3px]"></div>
      <div class="absolute top-[55%] right-[10%] size-2.5 rounded-full bg-gold-400/12 blur-[4px]"></div>
      <div class="absolute bottom-[20%] left-[18%] size-1.5 rounded-full bg-gold-400/15 blur-[2px]"></div>
      <div class="absolute top-[75%] right-[25%] size-1 rounded-full bg-gold-400/20 blur-sm"></div>
      <div class="absolute top-[35%] left-[45%] size-1 rounded-full bg-gold-400/10 blur-sm"></div>
    </div>
    <div class="container-site relative py-16 sm:py-20 lg:py-28">
      <Breadcrumb items={[{ label: 'Berita & Acara', href: '/berita/' }]} />
      <p class="text-[0.68rem] font-bold tracking-[0.26em] text-gold-300 uppercase">Dari komuniti PESUMA</p>
      <h1 class="mt-8 max-w-4xl font-serif text-[2.5rem] leading-[1.05] font-normal tracking-[-0.03em] sm:text-[3.25rem] lg:text-[4rem]">
        Berita & Perkembangan
      </h1>
      <p class="mt-5 max-w-2xl border-l border-gold-400/60 pl-6 text-base leading-8 text-slate-300 sm:text-lg">
        Program, aktiviti, pengumuman dan perkembangan terkini dari komuniti PESUMA.
      </p>
    </div>
  </section>

  <!-- ═══════════ BERITA KOSONG ═══════════ -->
  {posts.length === 0 && events.length === 0 && (
    <section class="bg-cream-50 section-pad text-center">
      <div class="container-site max-w-xl">
        <h2 class="font-serif text-3xl font-normal text-navy-900">Belum ada berita atau acara buat masa ini.</h2>
        <p class="mt-5 text-sm leading-7 text-slate-600">Kembali lagi nanti untuk mengetahui perkembangan terkini PESUMA.</p>
      </div>
    </section>
  )}

  <!-- ═══════════ FEATURED POST ═══════════ -->
  {featuredPost && (
    <section class="bg-cream-50 section-pad">
      <div class="container-site">
        <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
          <VisualPlaceholder variant="navy" aspect="wide" label={featuredPost.category} />
          <div>
            <time datetime={featuredPost.date} class="text-[0.65rem] font-bold tracking-widest text-slate-500 uppercase">{formatDate(featuredPost.date)}</time>
            <h2 class="mt-4 font-serif text-3xl leading-tight font-normal text-navy-900 sm:text-4xl">
              <a href={`/berita/${featuredPost.slug}/`} class="transition-colors duration-[var(--transition-fast)] hover:text-gold-500">{featuredPost.title}</a>
            </h2>
            <p class="mt-5 max-w-xl text-sm leading-7 text-slate-600">{featuredPost.excerpt}</p>
            <a href={`/berita/${featuredPost.slug}/`} class="link-arrow mt-6">Baca Selanjutnya <Icon name="arrow" /></a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ GRID BERITA ═══════════ -->
  {remainingPosts.length > 0 && (
    <section class="bg-white section-pad">
      <div class="container-site">
        <div class="mb-10 border-b border-navy-900/15 pb-6">
          <h2 class="font-serif text-[1.875rem] leading-[1.12] font-normal tracking-[-0.02em] text-navy-900 sm:text-[2.25rem]">Berita Lain</h2>
        </div>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {remainingPosts.map((post) => (
            <article class="group">
              <VisualPlaceholder variant="cream" aspect="wide" label={post.category} />
              <time datetime={post.date} class="mt-5 block text-[0.6rem] font-bold tracking-widest text-slate-500 uppercase">{formatDate(post.date)}</time>
              <h3 class="mt-3 font-serif text-xl leading-snug font-normal text-navy-900 transition-colors duration-[var(--transition-fast)] group-hover:text-gold-500 sm:text-2xl">
                <a href={`/berita/${post.slug}/`}>{post.title}</a>
              </h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{post.excerpt}</p>
              <a href={`/berita/${post.slug}/`} class="link-arrow mt-4">Baca <Icon name="arrow" /></a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ ACARA AKAN DATANG ═══════════ -->
  {upcomingEvents.length > 0 && (
    <section class="bg-navy-950 text-white section-pad">
      <div class="container-site">
        <h2 class="font-serif text-[1.875rem] leading-[1.12] font-normal tracking-[-0.02em] text-white sm:text-[2.25rem]">Acara Akan Datang</h2>
        <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {upcomingEvents.map((event) => (
            <article class="border border-white/10 bg-white/[0.03] p-8 transition-all duration-[var(--transition-base)] hover:border-gold-400/30 hover:bg-white/[0.06]">
              <span class="inline-block border border-gold-300/40 px-3 py-1 text-[0.55rem] font-bold tracking-[0.14em] text-gold-300 uppercase">{event.status}</span>
              <h3 class="mt-5 font-serif text-2xl leading-snug font-normal">{event.title}</h3>
              <p class="mt-4 text-sm leading-6 text-slate-300">{event.excerpt}</p>
              <div class="mt-6 flex flex-wrap gap-4 border-t border-white/10 pt-5 text-xs text-slate-400">
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="calendar" size={14} /> {formatDate(event.date)}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="location" size={14} /> {event.location}
                </span>
              </div>
              {event.registrationUrl && (
                <a href={event.registrationUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-6 text-[0.6rem]">Daftar Sekarang <Icon name="external" size={14} /></a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ ACARA LEPAS ═══════════ -->
  {pastEvents.length > 0 && (
    <section class="bg-cream-50 section-pad">
      <div class="container-site">
        <h2 class="font-serif text-[1.875rem] leading-[1.12] font-normal tracking-[-0.02em] text-navy-900 sm:text-[2.25rem]">Acara Terdahulu</h2>
        <div class="mt-10 divide-y divide-navy-900/15">
          {pastEvents.map((event) => (
            <article class="grid gap-4 py-6 sm:grid-cols-[1fr_auto] sm:items-center">
              <div>
                <span class="text-[0.55rem] font-bold tracking-[0.16em] text-gold-500 uppercase">{event.status}</span>
                <h3 class="mt-1 font-serif text-xl font-normal text-navy-900">{event.title}</h3>
                <p class="mt-1 text-sm text-slate-500">{formatDate(event.date)} — {event.location}</p>
              </div>
              {event.excerpt && (
                <p class="max-w-md text-sm leading-6 text-slate-600">{event.excerpt}</p>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════ CTA ═══════════ -->
  <section class="bg-navy-900 section-pad text-center">
    <div class="container-site">
      <p class="text-[0.65rem] font-bold tracking-[0.24em] text-gold-300 uppercase">Kekal Terkini</p>
      <h2 class="mx-auto mt-6 max-w-2xl font-serif text-[1.875rem] leading-[1.12] font-normal text-white sm:text-[2.25rem]">Ikuti perkembangan terbaru dari komuniti PESUMA.</h2>
      <a href="/keahlian/" class="btn-primary mt-9">Daftar Sebagai Ahli <Icon name="arrow" /></a>
    </div>
  </section>
</BaseLayout>
